подключить "запрос" как запрос
подключить "клиент" как клиент

класс Сессия {
    приватный клиент: клиент.Клиент

    конструктор создать(это) {
        это.клиент = новый клиент.Клиент()
    }

    публичный функция запрос(это) {
        вернуть новый запрос.Запрос(это.клиент) 
    }

    публичный функция закрыть(это) {
        запрос.http_client_free(это.клиент.экземпляр)
    }
}